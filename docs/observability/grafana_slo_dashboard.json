{
  "title": "Backend SLO Dashboard",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(api_requests_total[5m]))" }]
    },
    {
      "title": "5xx Ratio",
      "type": "timeseries",
      "targets": [{ "expr": "api_5xx_ratio" }]
    },
    {
      "title": "Latency P95",
      "type": "timeseries",
      "targets": [{ "expr": "api_latency_p95_seconds" }]
    },
    {
      "title": "Automation Failure Ratio",
      "type": "timeseries",
      "targets": [{ "expr": "automation_run_failure_ratio" }]
    }
  ]
}
